            const servicesPreview = document.getElementById('servicesPreview');
            const allServices = document.getElementById('allServices');
            
            // Clear previous content
            servicesPreview.innerHTML = '';
            allServices.innerHTML = '';
            
            // Add services to preview (only 4)
            services.slice(0, 4).forEach(service => {
                servicesPreview.innerHTML += createServiceCard(service, false);
            });
            
            // Add all services
            services.forEach(service => {
                allServices.innerHTML += createServiceCard(service, false);
            });
        }
        
        // Function to load user's jobs
        function loadMyJobs() {
            const myJobsContainer = document.getElementById('myJobs');
            myJobsContainer.innerHTML = '';
            
            myJobs.forEach(job => {
                myJobsContainer.innerHTML += createServiceCard(job, true);
            });
        }
        
        // Function to create service card HTML
        function createServiceCard(item, isMyJob = false) {
            const hiddenInfoHTML = item.hiddenInfo ? `
                <div class="service-hidden-info">
                    <div class="hidden-info-label">Ism:</div>
                    <div class="hidden-info-value">${item.hiddenInfo.name}</div>
                    
                    <div class="hidden-info-label">Telefon:</div>
                    <div class="hidden-info-value">${item.hiddenInfo.phone}</div>
                    
                    <div class="hidden-info-label">Manzil:</div>
                    <div class="hidden-info-value">${item.hiddenInfo.address}</div>
                    
                    <div class="hidden-info-label">Ish vaqti:</div>
                    <div class="hidden-info-value">${item.hiddenInfo.experience}</div>
                    
                    <div class="hidden-info-label">Reyting:</div>
                    <div class="hidden-info-value">${item.hiddenInfo.rating}</div>
                </div>
            ` : '';
            
            const actionButtons = isMyJob ? `
                <div class="job-actions">
                    <button class="btn btn-edit" onclick="editJob(${item.id})">
                        <i class="fas fa-edit"></i> Tahrirlash
                    </button>
                    <button class="btn btn-delete" onclick="deleteJob(${item.id})">
                        <i class="fas fa-trash"></i> O'chirish
                    </button>
                </div>
            ` : '';
            
            const onClick = isMyJob ? `viewServiceDetails(${item.id}, true)` : `viewServiceDetails(${item.id})`;
            
            return `
                <div class="service-card ${isMyJob ? 'my-job' : ''}" data-id="${item.id}" onclick="${onClick}">
                    <div class="service-icon">
                        <i class="${item.icon}"></i>
                    </div>
                    <h3 class="service-title">${item.title}</h3>
                    <p>${item.description}</p>
                    <div class="service-price">${item.price}</div>
                    ${hiddenInfoHTML}
                    ${actionButtons}
                </div>
            `;
        }
        
        // Function to update modal balance
        function updateModalBalance() {
            const balance = document.getElementById('userBalance').textContent;
            document.getElementById('modalBalance').textContent = balance + ' UZS';
        }
        
        // Override showPaymentModal to update service title
        const originalShowPaymentModal = window.showPaymentModal;
        window.showPaymentModal = function(serviceId, serviceTitle) {
            originalShowPaymentModal(serviceId, serviceTitle);
            document.getElementById('paymentServiceTitle').textContent = `"${serviceTitle}" uchun`;
            updateModalBalance();
        };
        
        // Override processTopup to update header balance
        const originalProcessTopup = window.processTopup;
        window.processTopup = function() {
            originalProcessTopup();
            updateModalBalance();
        };
        
        // Override selectTopupAmount to update button text
        const originalSelectTopupAmount = window.selectTopupAmount;
        window.selectTopupAmount = function(amount) {
            originalSelectTopupAmount(amount);
            document.getElementById('selectedAmountText').textContent = amount.toLocaleString('uz-UZ');
        };
    </script>
</body>
</html>
